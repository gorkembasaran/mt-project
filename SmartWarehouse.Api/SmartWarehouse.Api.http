@SmartWarehouseApiHostAddress = http://localhost:5057
@CompanyId = COMP-001
@WarehouseLocationId = 1
@ProductId = 1

###
POST {{SmartWarehouseApiHostAddress}}/api/warehouse-locations/create
Content-Type: application/json

{
  "CompanyId": "{{CompanyId}}",
  "LocationCode": "A5-2",
  "ZoneName": "A",
  "Description": "A bölgesi / A5-2 rafı"
}

###
GET {{SmartWarehouseApiHostAddress}}/api/warehouse-locations/by-company/{{CompanyId}}
Accept: application/json

###
GET {{SmartWarehouseApiHostAddress}}/api/warehouse-locations/{{WarehouseLocationId}}?companyId={{CompanyId}}
Accept: application/json

###
POST {{SmartWarehouseApiHostAddress}}/api/products/create
Content-Type: application/json

{
  "CompanyId": "{{CompanyId}}",
  "ProductName": "Laptop Bilgisayar",
  "Sku": "PRD-0001",
  "Category": "Elektronik",
  "Unit": "Adet",
  "UnitPrice": 3764.42,
  "MinimumStock": 3,
  "WarehouseLocationId": {{WarehouseLocationId}}
}

###
GET {{SmartWarehouseApiHostAddress}}/api/products/paged?companyId={{CompanyId}}&page=1&pageSize=25&search=laptop&category=Elektronik&zone=A&status=Yeterli
Accept: application/json

###
GET {{SmartWarehouseApiHostAddress}}/api/products/{{ProductId}}?companyId={{CompanyId}}
Accept: application/json

###
POST {{SmartWarehouseApiHostAddress}}/api/products/update
Content-Type: application/json

{
  "Id": {{ProductId}},
  "CompanyId": "{{CompanyId}}",
  "ProductName": "Laptop Bilgisayar Pro",
  "Sku": "PRD-0001",
  "Category": "Elektronik",
  "Unit": "Adet",
  "UnitPrice": 4120.00,
  "MinimumStock": 5,
  "WarehouseLocationId": {{WarehouseLocationId}}
}

###
POST {{SmartWarehouseApiHostAddress}}/api/stock-movements/entry
Content-Type: application/json

{
  "CompanyId": "{{CompanyId}}",
  "ProductId": {{ProductId}},
  "Quantity": 15,
  "Description": "Tedarikçi teslimatı"
}

###
POST {{SmartWarehouseApiHostAddress}}/api/stock-movements/exit
Content-Type: application/json

{
  "CompanyId": "{{CompanyId}}",
  "ProductId": {{ProductId}},
  "Quantity": 4,
  "Description": "Müşteri sevki"
}

###
GET {{SmartWarehouseApiHostAddress}}/api/stock-movements/by-company/{{CompanyId}}
Accept: application/json

###
POST {{SmartWarehouseApiHostAddress}}/api/products/delete
Content-Type: application/json

{
  "Id": {{ProductId}},
  "CompanyId": "{{CompanyId}}"
}

###
POST {{SmartWarehouseApiHostAddress}}/api/warehouse-locations/delete
Content-Type: application/json

{
  "Id": {{WarehouseLocationId}},
  "CompanyId": "{{CompanyId}}"
}
